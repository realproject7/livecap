{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "types": [
      "vitest/globals"
    ],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "test"
  ]
}