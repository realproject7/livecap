{
  "name": "livecap",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && tsc -p tsconfig.host.json && vite build && vite build --config vite.host.config.ts",
    "build:host": "tsc -p tsconfig.host.json && vite build --config vite.host.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint .",
    "typecheck": "tsc && tsc -p tsconfig.host.json",
    "test": "vitest run && pnpm -r --filter './packages/*' test",
    "test:app": "vitest run",
    "no-stub": "scripts/no-stub-gate.sh"
  },
  "dependencies": {
    "@livecap/archive": "workspace:*",
    "@livecap/engine": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22",
    "eslint": "^9",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8",
    "vite": "^6.0.3",
    "vitest": "^3"
  }
}
